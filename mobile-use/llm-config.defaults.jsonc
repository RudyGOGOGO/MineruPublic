// Here is the default config that will be used if no override is provided.
{
  "default": {
    "planner": {
      "provider": "openai",
      "model": "gpt-5-nano",
      "fallback": {
        "provider": "openai",
        "model": "gpt-5-mini"
      }
    },
    "orchestrator": {
      "provider": "openai",
      "model": "gpt-5-nano",
      "fallback": {
        "provider": "openai",
        "model": "gpt-5-mini"
      }
    },
    "cortex": {
      "provider": "openai",
      "model": "gpt-5",
      "fallback": {
        "provider": "openai",
        "model": "o4-mini"
      }
    },
    "executor": {
      "provider": "openai",
      "model": "gpt-5-nano",
      "fallback": {
        "provider": "openai",
        "model": "gpt-5-mini"
      }
    },
    "contextor": {
      "provider": "openai",
      "model": "gpt-5-nano",
      "fallback": {
        "provider": "openai",
        "model": "gpt-5-mini"
      }
    },
    "utils": {
      "hopper": {
        // Needs at least a 256k context window.
        "provider": "openai",
        "model": "gpt-5-nano",
        "fallback": {
          "provider": "openai",
          "model": "gpt-5-mini"
        }
      },
      "outputter": {
        "provider": "openai",
        "model": "gpt-5-nano",
        "fallback": {
          "provider": "openai",
          "model": "gpt-5-mini"
        }
      }
      // video_analyzer is optional - only needed when using video recording tools
      // Requires a video-capable model (Google). To enable, uncomment below:
      // "video_analyzer": {
      //   "provider": "google",
      //   "model": "gemini-3-flash-preview",
      //   "fallback": {
      //     "provider": "google",
      //     "model": "gemini-2.5-flash"
      //   }
      // }
    }
  },
  // This is the config we recommend.
  // To use it, copy it to llm-config.override.jsonc, following llm-config.override.template.jsonc.
  "recommended": {
    "planner": {
      "provider": "mineru",
      "model": "meta-llama/llama-4-scout",
      "fallback": {
        "provider": "mineru",
        "model": "meta-llama/llama-4-maverick"
      }
    },
    "orchestrator": {
      "provider": "mineru",
      "model": "openai/gpt-oss-120b",
      "fallback": {
        "provider": "mineru",
        "model": "meta-llama/llama-4-maverick"
      }
    },
    "cortex": {
      "provider": "mineru",
      "model": "google/gemini-3-pro-preview",
      "fallback": {
        "provider": "mineru",
        "model": "google/gemini-2.5-pro"
      }
    },
    "executor": {
      "provider": "mineru",
      "model": "meta-llama/llama-3.1-70b-instruct",
      "fallback": {
        "provider": "mineru",
        "model": "openai/gpt-5-mini"
      }
    },
    "contextor": {
      "provider": "mineru",
      "model": "meta-llama/llama-3.1-8b-instruct",
      "fallback": {
        "provider": "mineru",
        "model": "meta-llama/llama-3.3-70b-instruct"
      }
    },
    "utils": {
      "hopper": {
        // Needs at least a 256k context window.
        "provider": "mineru",
        "model": "openai/gpt-5-nano",
        "fallback": {
          "provider": "mineru",
          "model": "openai/gpt-5-mini"
        }
      },
      "outputter": {
        "provider": "mineru",
        "model": "openai/gpt-5-nano",
        "fallback": {
          "provider": "mineru",
          "model": "openai/gpt-5-mini"
        }
      },
      // video_analyzer is optional - only needed when using video recording tools
      // Requires a video-capable model. Ex of supported models:
      // gemini-3-pro-preview, gemini-3-flash-preview, gemini-2.5-flash,
      // gemini-2.5-flash-lite, gemini-2.5-pro, gemini-2.0-flash, gemini-2.0-flash-lite
      "video_analyzer": {
        "provider": "mineru",
        "model": "google/gemini-3-flash-preview",
        "fallback": {
          "provider": "mineru",
          "model": "google/gemini-2.5-flash"
        }
      }
    }
  },
  // GUI Owl VLM config: uses local MLX_GUI_Owl_8B_16bits model for vision-capable agents
  // and Claude CLI as fallback. Start with: --model-provider gui_owl
  "gui_owl": {
    "planner": {
      "provider": "claude",
      "model": "claude",
      "fallback": {
        "provider": "gui_owl",
        "model": "MLX_GUI_Owl_8B_16bits"
      }
    },
    "orchestrator": {
      "provider": "claude",
      "model": "claude",
      "fallback": {
        "provider": "gui_owl",
        "model": "MLX_GUI_Owl_8B_16bits"
      }
    },
    "cortex": {
      // Cortex needs complex structured JSON decisions — Claude handles this better.
      // GUI Owl 8B is a visual grounding model, not suited for multi-field structured output.
      "provider": "claude",
      "model": "claude",
      "fallback": {
        "provider": "gui_owl",
        "model": "MLX_GUI_Owl_8B_16bits"
      }
    },
    "executor": {
      "provider": "claude",
      "model": "claude",
      "fallback": {
        "provider": "gui_owl",
        "model": "MLX_GUI_Owl_8B_16bits"
      }
    },
    "contextor": {
      // GUI Owl can analyze screenshots for context extraction
      "provider": "gui_owl",
      "model": "MLX_GUI_Owl_8B_16bits",
      "fallback": {
        "provider": "claude",
        "model": "claude"
      }
    },
    "utils": {
      "hopper": {
        "provider": "claude",
        "model": "claude",
        "fallback": {
          "provider": "claude",
          "model": "claude"
        }
      },
      "outputter": {
        "provider": "claude",
        "model": "claude",
        "fallback": {
          "provider": "claude",
          "model": "claude"
        }
      }
    }
  }
}
